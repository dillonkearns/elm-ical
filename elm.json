{
    "type": "package",
    "name": "dillonkearns/elm-ical",
    "summary": "Generate and parse iCal (RFC 5545) calendar feeds.",
    "license": "BSD-3-Clause",
    "version": "1.0.0",
    "exposed-modules": [
        "Ical",
        "Ical.Generator",
        "Ical.Parser",
        "Ical.Recurrence"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.5 <= v < 2.0.0",
        "elm/regex": "1.0.0 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0",
        "justinmimbs/date": "4.1.0 <= v < 5.0.0",
        "ryan-haskell/date-format": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.2.1 <= v < 3.0.0",
        "rtfeldman/elm-iso8601-date-strings": "1.1.4 <= v < 2.0.0"
    }
}
